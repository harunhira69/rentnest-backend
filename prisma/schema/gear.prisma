model GearItem {
  id                String  @id @default(uuid())
  name              String
  description       String
  brand             String
  pricePerDay       Float
  stock             Int
  availableQuantity Int
  imageUrl          String?
  specifications    Json?
  isAvailable       Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  providerId String
  provider   User   @relation("ProviderGearItems", fields: [providerId], references: [id])

  rentalOrderItems RentalOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([providerId])
  @@index([brand])
  @@index([pricePerDay])
  @@map("gear_items")
}
